              "features/dashboard",
              "features/statistics",
              "features/analytics",
              "features/about"
            ]
          },
          {
            "group": "Business Modules",
            "pages": [
              "modules/sales",
              "modules/clients",
              "modules/invoices",
              "modules/messages"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "config/settings",
              "config/security",
              "config/notifications"
            ]
          }
        ]
      },
      {
        "tab": "Development",
        "groups": [
          {
            "group": "Architecture",
            "pages": [
              "development/structure",
              "development/models",
