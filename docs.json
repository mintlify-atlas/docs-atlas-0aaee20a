{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Dashboard Laravel",
  "theme": "maple",
  "colors": {
    "primary": "#94cb04",
    "light": "#545454",
    "dark": "#94cb04"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo-light.png",
    "dark": "/logo-light.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/sofih-ii/Dashboard_php"
    }
  },
  "footer": {
